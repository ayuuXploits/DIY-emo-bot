/*
 * VIRAL MOCHI BOT - Wemos D1 Mini Edition
 * Features: OLED Display, Touch Sensor Control, Multiple Animations
 * 
 * Pinout:
 * OLED SDA -> D2 (GPIO4)
 * OLED SCL -> D1 (GPIO5)
 * Touch Sensor SIGNAL -> D5 (GPIO14)
 */

#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// OLED Display Setup
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

// Pin Definitions
#define TOUCH_PIN D5    // GPIO14
#define SDA_PIN D2      // GPIO4
#define SCL_PIN D1      // GPIO5

// Create display object
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// Animation States
enum AnimationState {
  HAPPY_BOUNCE,
  CUTE_SPIN,
  WINK_BLINK,
  HEART_LOVE,
  DIZZY_SPIN,
  SLEEP_MODE,
  DANCE_PARTY
};

AnimationState currentAnimation = HAPPY_BOUNCE;
unsigned long lastTapTime = 0;
unsigned long animationStartTime = 0;
bool lastTouchState = false;

void setup() {
  Serial.begin(115200);
  delay(100);
  
  Serial.println("\n\nMOCHI BOT Starting...");
  
  // Initialize I2C with custom pins
  Wire.begin(SDA_PIN, SCL_PIN);
  
  // Initialize OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    while (1);
  }
  
  // Setup touch sensor
  pinMode(TOUCH_PIN, INPUT);
  
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(20, 25);
  display.println("MOCHI BOT");
  display.setCursor(15, 40);
  display.println("Booting up...");
  display.display();
  
  delay(1500);
  
  animationStartTime = millis();
  
  Serial.println("Setup complete! Touch sensor ready on pin D5");
}

void loop() {
  // Check touch sensor
  bool currentTouchState = digitalRead(TOUCH_PIN);
  
  // Detect touch (transition from HIGH to LOW)
  if (!currentTouchState && lastTouchState) {
    handleTap();
  }
  
  lastTouchState = currentTouchState;
  
  // Clear and draw current animation
  display.clearDisplay();
  
  switch (currentAnimation) {
    case HAPPY_BOUNCE:
      drawHappyBounce();
      break;
    case CUTE_SPIN:
      drawCuteSpin();
      break;
    case WINK_BLINK:
      drawWinkBlink();
      break;
    case HEART_LOVE:
      drawHeartLove();
      break;
    case DIZZY_SPIN:
      drawDizzySpin();
      break;
    case SLEEP_MODE:
      drawSleepMode();
      break;
    case DANCE_PARTY:
      drawDanceParty();
      break;
  }
  
  display.display();
  delay(50);
}

void handleTap() {
  lastTapTime = millis();
  
  // Cycle through animations
  currentAnimation = (AnimationState)((currentAnimation + 1) % 7);
  animationStartTime = millis();
  
  Serial.print("Animation changed to: ");
  Serial.println(currentAnimation);
}

// ================== ANIMATION FUNCTIONS ==================

void drawHappyBounce() {
  unsigned long elapsed = millis() - animationStartTime;
  float bounce = sin((elapsed / 500.0) * PI) * 8;
  
  int mochY = 32 - bounce;
  
  // Draw bouncing mochi
  display.fillCircle(64, mochY, 16, SSD1306_WHITE);
  
  // Happy eyes
  display.fillCircle(60, mochY - 4, 2, SSD1306_BLACK);
  display.fillCircle(68, mochY - 4, 2, SSD1306_BLACK);
  
  // Happy mouth
  display.drawLine(60, mochY + 5, 68, mochY + 5, SSD1306_BLACK);
  display.drawLine(60, mochY + 6, 68, mochY + 6, SSD1306_BLACK);
  
  // Ground line
  display.drawLine(30, 50, 98, 50, SSD1306_WHITE);
  
  // Label
  display.setTextSize(1);
  display.setCursor(45, 55);
  display.println("BOUNCY!");
}

void drawCuteSpin() {
  unsigned long elapsed = millis() - animationStartTime;
  float rotation = (elapsed / 20.0);
  
  int centerX = 64;
  int centerY = 32;
  int radius = 12;
  
  // Draw rotating mochi
  display.fillCircle(centerX, centerY, 14, SSD1306_WHITE);
  
  // Eyes that follow rotation
  float eyeAngle = rotation * PI / 180.0;
  int eye1X = centerX + cos(eyeAngle) * 6;
  int eye1Y = centerY + sin(eyeAngle) * 6 - 2;
  
  display.fillCircle(eye1X, eye1Y, 2, SSD1306_BLACK);
  
  float eyeAngle2 = eyeAngle + PI;
  int eye2X = centerX + cos(eyeAngle2) * 6;
  int eye2Y = centerY + sin(eyeAngle2) * 6 - 2;
  display.fillCircle(eye2X, eye2Y, 2, SSD1306_BLACK);
  
  // Spinning indicator
  int dotX = centerX + cos(eyeAngle * 2) * 18;
  int dotY = centerY + sin(eyeAngle * 2) * 18;
  display.fillCircle(dotX, dotY, 1, SSD1306_WHITE);
  
  display.setTextSize(1);
  display.setCursor(48, 55);
  display.println("SPIN SPIN!");
}

void drawWinkBlink() {
  unsigned long elapsed = millis() - animationStartTime;
  int phase = (elapsed / 300) % 4;
  
  int mochX = 64;
  int mochY = 32;
  
  // Draw mochi
  display.fillCircle(mochX, mochY, 14, SSD1306_WHITE);
  
  // Left eye
  if (phase < 2) {
    display.fillCircle(60, mochY - 4, 2, SSD1306_BLACK);
  } else {
    display.drawLine(59, mochY - 4, 61, mochY - 4, SSD1306_BLACK);
  }
  
  // Right eye (winking)
  if (phase == 1 || phase == 3) {
    display.drawLine(67, mochY - 4, 69, mochY - 4, SSD1306_BLACK);
  } else {
    display.fillCircle(68, mochY - 4, 2, SSD1306_BLACK);
  }
  
  // Smile
  display.drawLine(60, mochY + 4, 68, mochY + 4, SSD1306_BLACK);
  
  // Blush
  display.drawCircle(55, mochY + 2, 1, SSD1306_BLACK);
  display.drawCircle(73, mochY + 2, 1, SSD1306_BLACK);
  
  display.setTextSize(1);
  display.setCursor(45, 55);
  display.println("WINK WINK!");
}

void drawHeartLove() {
  unsigned long elapsed = millis() - animationStartTime;
  float scale = 0.8 + sin((elapsed / 400.0) * PI) * 0.3;
  
  int mochX = 64;
  int mochY = 28;
  
  // Draw mochi
  display.fillCircle(mochX, mochY, 14, SSD1306_WHITE);
  
  // Heart eyes
  drawSmallHeart(58, mochY - 3, scale);
  drawSmallHeart(70, mochY - 3, scale);
  
  // Love mouth
  display.drawLine(62, mochY + 5, 66, mochY + 5, SSD1306_BLACK);
  display.drawLine(62, mochY + 6, 66, mochY + 6, SSD1306_BLACK);
  
  // Floating hearts
  for (int i = 0; i < 3; i++) {
    float hx = 30 + i * 30 + sin((elapsed / 500.0 + i) * PI) * 5;
    float hy = 15 - (elapsed / 3000.0) * 20 + i * 5;
    if (hy > 0) {
      drawTinyHeart(hx, hy);
    }
  }
  
  display.setTextSize(1);
  display.setCursor(48, 55);
  display.println("LOVE ME!");
}

void drawDizzySpin() {
  unsigned long elapsed = millis() - animationStartTime;
  int rotation = (elapsed / 40) % 360;
  
  int mochX = 64;
  int mochY = 32;
  
  // Draw mochi
  display.fillCircle(mochX, mochY, 14, SSD1306_WHITE);
  
  // Dizzy spiral eyes
  drawDizzyEye(58, mochY - 2, rotation);
  drawDizzyEye(70, mochY - 2, rotation + 180);
  
  // Dizzy mouth
  display.drawLine(62, mochY + 6, 66, mochY + 6, SSD1306_BLACK);
  display.drawLine(61, mochY + 7, 67, mochY + 7, SSD1306_BLACK);
  
  display.setTextSize(1);
  display.setCursor(42, 55);
  display.println("WHIRRRRR!");
}

void drawSleepMode() {
  unsigned long elapsed = millis() - animationStartTime;
  float yOffset = sin((elapsed / 1000.0) * PI) * 2;
  
  int mochX = 64;
  int mochY = 32 + yOffset;
  
  // Draw sleeping mochi
  display.fillCircle(mochX, mochY, 14, SSD1306_WHITE);
  
  // Closed eyes (curved lines)
  display.drawLine(58, mochY - 3, 62, mochY - 3, SSD1306_BLACK);
  display.drawLine(66, mochY - 3, 70, mochY - 3, SSD1306_BLACK);
  
  // Sleeping smile
  display.drawLine(60, mochY + 5, 68, mochY + 5, SSD1306_BLACK);
  
  // ZZZ
  display.setTextSize(1);
  for (int i = 0; i < 3; i++) {
    int zY = 15 - i * 10;
    int zX = 85 + (elapsed / 400 - i) * 2;
    if (zX < 128) {
      display.drawLine(zX, zY, zX + 4, zY + 4, SSD1306_WHITE);
    }
  }
  
  display.setTextSize(1);
  display.setCursor(45, 55);
  display.println("ZZZ ZZZ");
}

void drawDanceParty() {
  unsigned long elapsed = millis() - animationStartTime;
  float moveX = sin((elapsed / 300.0) * PI) * 8;
  
  int mochX = 64 + moveX;
  int mochY = 32;
  
  // Draw dancing mochi
  display.fillCircle(mochX, mochY, 14, SSD1306_WHITE);
  
  // Dancing eyes
  display.fillCircle(mochX - 4, mochY - 4, 2, SSD1306_BLACK);
  display.fillCircle(mochX + 4, mochY - 4, 2, SSD1306_BLACK);
  
  // Dancing smile
  display.drawLine(mochX - 4, mochY + 5, mochX + 4, mochY + 5, SSD1306_BLACK);
  display.drawLine(mochX - 4, mochY + 6, mochX + 4, mochY + 6, SSD1306_BLACK);
  
  // Party confetti
  for (int i = 0; i < 5; i++) {
    float confettiX = 20 + i * 25 + sin((elapsed / 200.0 + i) * PI) * 5;
    float confettiY = 15 + (elapsed / 100.0 + i * 3) % 20;
    display.fillRect(confettiX, confettiY, 2, 2, SSD1306_WHITE);
  }
  
  display.setTextSize(1);
  display.setCursor(42, 55);
  display.println("PARTY TIME!");
}

// ================== HELPER DRAWING FUNCTIONS ==================

void drawSmallHeart(int x, int y, float scale) {
  int s = scale * 2;
  display.drawPixel(x, y - s, SSD1306_BLACK);
  display.drawPixel(x - s, y - s + 1, SSD1306_BLACK);
  display.drawPixel(x + s, y - s + 1, SSD1306_BLACK);
  display.drawPixel(x - s, y, SSD1306_BLACK);
  display.drawPixel(x, y, SSD1306_BLACK);
  display.drawPixel(x + s, y, SSD1306_BLACK);
  display.drawPixel(x, y + s, SSD1306_BLACK);
}

void drawTinyHeart(float x, float y) {
  display.drawPixel(x, y - 1, SSD1306_WHITE);
  display.drawPixel(x - 1, y, SSD1306_WHITE);
  display.drawPixel(x, y, SSD1306_WHITE);
  display.drawPixel(x + 1, y, SSD1306_WHITE);
  display.drawPixel(x, y + 1, SSD1306_WHITE);
}

void drawDizzyEye(int x, int y, int rotation) {
  int angle = rotation % 360;
  
  for (int i = 0; i < 8; i++) {
    float lineAngle = (i * 45 + angle) * PI / 180.0;
    int px = x + cos(lineAngle) * 2;
    int py = y + sin(lineAngle) * 2;
    display.drawPixel(px, py, SSD1306_BLACK);
  }
}
