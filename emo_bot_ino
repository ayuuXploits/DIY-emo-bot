/*
 * CUTE FACE MOCHI BOT - Full Screen Anime Face
 * Features: Big anime eyes, full-screen face, touch-controlled animations
 * Style: Like ekik/mochi bots with expressive cute faces
 * 
 * Pinout:
 * OLED SDA -> D2 (GPIO4)
 * OLED SCL -> D1 (GPIO5)
 * Touch Sensor SIGNAL -> D5 (GPIO14)
 */

#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SSD1306.h>

// OLED Display Setup
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

// Pin Definitions
#define TOUCH_PIN D5    // GPIO14
#define SDA_PIN D2      // GPIO4
#define SCL_PIN D1      // GPIO5

// Create display object
Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// Animation States
enum AnimationState {
  HAPPY,
  BLINKING,
  LOVE_EYES,
  SHOCKED,
  SLEEPY,
  EXCITED,
  SHY
};

AnimationState currentAnimation = HAPPY;
unsigned long animationStartTime = 0;
bool lastTouchState = false;

void setup() {
  Serial.begin(115200);
  delay(100);
  
  Serial.println("\n\nCUTE FACE BOT Starting...");
  
  // Initialize I2C with custom pins
  Wire.begin(SDA_PIN, SCL_PIN);
  
  // Initialize OLED
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println(F("SSD1306 allocation failed"));
    while (1);
  }
  
  // Setup touch sensor
  pinMode(TOUCH_PIN, INPUT);
  
  // Boot screen
  display.clearDisplay();
  display.setTextSize(2);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(15, 25);
  display.println("CUTE BOT");
  display.display();
  delay(1500);
  
  animationStartTime = millis();
  
  Serial.println("Setup complete! Touch sensor ready on pin D5");
}

void loop() {
  // Check touch sensor
  bool currentTouchState = digitalRead(TOUCH_PIN);
  
  // Detect touch (transition from HIGH to LOW)
  if (!currentTouchState && lastTouchState) {
    handleTap();
  }
  
  lastTouchState = currentTouchState;
  
  // Clear and draw current animation
  display.clearDisplay();
  
  switch (currentAnimation) {
    case HAPPY:
      drawHappyFace();
      break;
    case BLINKING:
      drawBlinkingFace();
      break;
    case LOVE_EYES:
      drawLoveEyesFace();
      break;
    case SHOCKED:
      drawShockedFace();
      break;
    case SLEEPY:
      drawSleepyFace();
      break;
    case EXCITED:
      drawExcitedFace();
      break;
    case SHY:
      drawShyFace();
      break;
  }
  
  display.display();
  delay(50);
}

void handleTap() {
  // Cycle through animations
  currentAnimation = (AnimationState)((currentAnimation + 1) % 7);
  animationStartTime = millis();
  
  Serial.print("Face changed to: ");
  Serial.println(currentAnimation);
}

// ================== FACE DRAWING FUNCTIONS ==================

void drawHappyFace() {
  unsigned long elapsed = millis() - animationStartTime;
  
  // Draw face outline (circle/rounded shape)
  drawFaceOutline();
  
  // Draw big happy eyes
  drawBigEye(35, 22, 0);  // Left eye
  drawBigEye(93, 22, 0);  // Right eye
  
  // Draw happy mouth
  display.drawLine(40, 45, 88, 45, SSD1306_WHITE);  // Mouth line
  display.drawLine(40, 46, 88, 46, SSD1306_WHITE);
  display.drawLine(40, 47, 88, 47, SSD1306_WHITE);
  
  // Happy smile arc
  for (int i = 0; i < 12; i++) {
    float angle = (i / 12.0) * PI;
    int x = 40 + i * 4;
    int y = 48 + sin(angle) * 3;
    display.drawPixel(x, y, SSD1306_WHITE);
  }
  
  // Blush marks
  drawBlush(25, 38);
  drawBlush(103, 38);
}

void drawBlinkingFace() {
  unsigned long elapsed = millis() - animationStartTime;
  int phase = (elapsed / 400) % 5;  // Blink cycle
  
  drawFaceOutline();
  
  // Left eye - normal
  drawBigEye(35, 22, 0);
  
  // Right eye - blinking
  if (phase == 0 || phase == 1) {
    drawBigEye(93, 22, 0);  // Open
  } else if (phase == 2) {
    drawClosedEye(93, 22);  // Closed
  } else {
    drawBigEye(93, 22, 0);  // Open again
  }
  
  // Gentle smile
  display.drawLine(45, 46, 83, 46, SSD1306_WHITE);
  display.drawLine(45, 47, 83, 47, SSD1306_WHITE);
  
  for (int i = 0; i < 10; i++) {
    float angle = (i / 10.0) * PI;
    int x = 45 + i * 3.8;
    int y = 48 + sin(angle) * 2;
    display.drawPixel(x, y, SSD1306_WHITE);
  }
}

void drawLoveEyesFace() {
  unsigned long elapsed = millis() - animationStartTime;
  float pulse = sin((elapsed / 500.0) * PI);
  
  drawFaceOutline();
  
  // Love eyes (heart shapes)
  drawHeartEye(35, 22, pulse);  // Left eye
  drawHeartEye(93, 22, pulse);  // Right eye
  
  // Love mouth (kiss shape)
  display.drawCircle(64, 47, 3, SSD1306_WHITE);
  display.drawCircle(64, 47, 2, SSD1306_WHITE);
  
  // Floating hearts around face
  drawTinyHeartAt(15, 10);
  drawTinyHeartAt(113, 10);
  drawTinyHeartAt(15, 50);
  drawTinyHeartAt(113, 50);
}

void drawShockedFace() {
  unsigned long elapsed = millis() - animationStartTime;
  
  drawFaceOutline();
  
  // Big shocked eyes (wide open circles)
  display.drawCircle(35, 22, 8, SSD1306_WHITE);
  display.drawCircle(35, 22, 7, SSD1306_WHITE);
  display.fillCircle(35, 22, 3, SSD1306_WHITE);  // Pupil
  
  display.drawCircle(93, 22, 8, SSD1306_WHITE);
  display.drawCircle(93, 22, 7, SSD1306_WHITE);
  display.fillCircle(93, 22, 3, SSD1306_WHITE);  // Pupil
  
  // O shaped mouth
  display.drawCircle(64, 48, 4, SSD1306_WHITE);
  display.drawCircle(64, 48, 3, SSD1306_WHITE);
}

void drawSleepyFace() {
  unsigned long elapsed = millis() - animationStartTime;
  float yBob = sin((elapsed / 1200.0) * PI) * 3;
  
  // Draw sleepy face outline
  drawFaceOutlineOffset(yBob);
  
  // Closed sleeping eyes (curved lines)
  display.drawLine(28, 22, 42, 20, SSD1306_WHITE);
  display.drawLine(28, 23, 42, 21, SSD1306_WHITE);
  
  display.drawLine(86, 20, 100, 22, SSD1306_WHITE);
  display.drawLine(86, 21, 100, 23, SSD1306_WHITE);
  
  // Peaceful smile
  display.drawLine(45, 47, 83, 47, SSD1306_WHITE);
  
  // ZZZ floating
  drawZZZ(110, 15 - yBob);
  drawZZZ(115, 10 - yBob);
  drawZZZ(110, 5 - yBob);
}

void drawExcitedFace() {
  unsigned long elapsed = millis() - animationStartTime;
  float bounce = sin((elapsed / 300.0) * PI) * 4;
  
  // Draw face outline with slight bounce
  drawFaceOutlineOffset(bounce);
  
  // Excited wide eyes
  drawBigEyeWide(35, 22);
  drawBigEyeWide(93, 22);
  
  // Big excited smile
  for (int i = 0; i < 15; i++) {
    float angle = (i / 15.0) * PI;
    int x = 38 + i * 2.6;
    int y = 48 + sin(angle) * 5;
    display.drawPixel(x, y, SSD1306_WHITE);
  }
  display.drawLine(40, 48, 88, 48, SSD1306_WHITE);
  display.drawLine(40, 49, 88, 49, SSD1306_WHITE);
  
  // Happy blush
  drawBlush(22, 38);
  drawBlush(106, 38);
}

void drawShyFace() {
  unsigned long elapsed = millis() - animationStartTime;
  
  drawFaceOutline();
  
  // Shy closed eyes (looking down)
  display.drawLine(30, 20, 40, 24, SSD1306_WHITE);
  display.drawLine(30, 21, 40, 25, SSD1306_WHITE);
  
  display.drawLine(88, 24, 98, 20, SSD1306_WHITE);
  display.drawLine(88, 25, 98, 21, SSD1306_WHITE);
  
  // Bashful smile (smaller)
  display.drawLine(50, 46, 78, 46, SSD1306_WHITE);
  
  for (int i = 0; i < 8; i++) {
    float angle = (i / 8.0) * PI;
    int x = 50 + i * 3.5;
    int y = 47 + sin(angle) * 2;
    display.drawPixel(x, y, SSD1306_WHITE);
  }
  
  // Big shy blush
  for (int i = 0; i < 6; i++) {
    display.drawCircle(22, 36 + i/2, 4 - i/2, SSD1306_WHITE);
  }
  for (int i = 0; i < 6; i++) {
    display.drawCircle(106, 36 + i/2, 4 - i/2, SSD1306_WHITE);
  }
}

// ================== DRAWING HELPER FUNCTIONS ==================

void drawFaceOutline() {
  drawFaceOutlineOffset(0);
}

void drawFaceOutlineOffset(float yOffset) {
  int centerX = 64;
  int centerY = 32 + yOffset;
  int radius = 28;
  
  // Draw face circle
  display.drawCircle(centerX, centerY, radius, SSD1306_WHITE);
  
  // Draw thicker outline
  for (int i = 1; i <= 2; i++) {
    display.drawCircle(centerX, centerY, radius - i, SSD1306_WHITE);
  }
}

void drawBigEye(int x, int y, int lookDirection) {
  // Eye white (sclera)
  display.drawCircle(x, y, 7, SSD1306_WHITE);
  display.drawCircle(x, y, 6, SSD1306_WHITE);
  
  // Iris
  int irisX = x + (lookDirection * 2);
  int irisY = y;
  display.fillCircle(irisX, irisY, 4, SSD1306_WHITE);
  
  // Pupil (shiny)
  display.fillCircle(irisX + 1, irisY - 1, 2, SSD1306_BLACK);
  
  // Eye shine (cute highlight)
  display.fillCircle(irisX + 2, irisY - 2, 1, SSD1306_WHITE);
}

void drawBigEyeWide(int x, int y) {
  // Wider excited eyes
  display.drawCircle(x, y, 8, SSD1306_WHITE);
  display.drawCircle(x, y, 7, SSD1306_WHITE);
  
  // Iris
  display.fillCircle(x, y, 4, SSD1306_WHITE);
  
  // Pupil
  display.fillCircle(x + 1, y - 1, 2, SSD1306_BLACK);
  
  // Shine
  display.fillCircle(x + 2, y - 2, 1, SSD1306_WHITE);
}

void drawClosedEye(int x, int y) {
  // Closed eye (curved line)
  display.drawLine(x - 6, y - 2, x + 6, y - 2, SSD1306_WHITE);
  display.drawLine(x - 6, y - 1, x + 6, y - 1, SSD1306_WHITE);
  display.drawLine(x - 6, y, x + 6, y, SSD1306_WHITE);
}

void drawHeartEye(int x, int y, float scale) {
  int size = 5 + (scale * 2);
  
  // Heart top points
  display.fillCircle(x - 2, y - 3, 2, SSD1306_WHITE);
  display.fillCircle(x + 2, y - 3, 2, SSD1306_WHITE);
  
  // Heart bottom point
  display.drawLine(x - 3, y, x, y + 5, SSD1306_WHITE);
  display.drawLine(x + 3, y, x, y + 5, SSD1306_WHITE);
  display.drawLine(x - 3, y + 1, x, y + 4, SSD1306_WHITE);
  display.drawLine(x + 3, y + 1, x, y + 4, SSD1306_WHITE);
}

void drawBlush(int x, int y) {
  // Cute circular blush
  display.drawCircle(x, y, 3, SSD1306_WHITE);
  display.drawCircle(x, y, 2, SSD1306_WHITE);
  display.drawPixel(x, y, SSD1306_WHITE);
  display.drawPixel(x + 1, y, SSD1306_WHITE);
  display.drawPixel(x, y + 1, SSD1306_WHITE);
}

void drawTinyHeartAt(int x, int y) {
  display.drawPixel(x, y - 1, SSD1306_WHITE);
  display.drawPixel(x - 1, y, SSD1306_WHITE);
  display.drawPixel(x, y, SSD1306_WHITE);
  display.drawPixel(x + 1, y, SSD1306_WHITE);
  display.drawPixel(x, y + 1, SSD1306_WHITE);
}

void drawZZZ(int x, int y) {
  // Draw Z shape
  display.drawLine(x, y, x + 2, y, SSD1306_WHITE);
  display.drawLine(x, y + 1, x + 2, y + 1, SSD1306_WHITE);
  display.drawLine(x + 2, y + 1, x, y + 3, SSD1306_WHITE);
  display.drawLine(x, y + 3, x + 2, y + 3, SSD1306_WHITE);
}
